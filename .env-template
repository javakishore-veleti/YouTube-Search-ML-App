# ─────────────────────────────────────────────────────────────────────────────
# YouTube Search ML App — environment template
# Copy to .env and fill in values.  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App secrets (used when NO secrets provider toggle is enabled) ─────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
DATABASE_URL=                        # leave blank → SQLite default (app/data/models.db)
                                     # postgresql+psycopg2://user:pass@host:5432/dbname
                                     # mysql+pymysql://user:pass@host:3306/dbname

# ─────────────────────────────────────────────────────────────────────────────
# Feature toggles — secrets provider
# Set exactly ONE to true.  All default to false → plain .env is used.
# ─────────────────────────────────────────────────────────────────────────────
FEATURES_DB_AWS_SECRETS_MGR_ENABLED=false
FEATURES_DB_AZURE_KEY_VAULT_ENABLED=false
FEATURES_DB_GCP_SECRET_MGR_ENABLED=false
FEATURES_DB_ENCRYPTED_FILE_ENABLED=false

# ── AWS Secrets Manager (requires: pip install boto3) ─────────────────────────
# Credentials: IAM role, ~/.aws/credentials, or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
AWS_SECRETS_MGR_SECRET_NAME=         # e.g. vidsage/prod/db
AWS_REGION=us-east-1

# ── Azure Key Vault (requires: pip install azure-keyvault-secrets azure-identity)
# Credentials: DefaultAzureCredential (workload identity / env vars / Azure CLI)
AZURE_KEY_VAULT_URL=                 # e.g. https://myvault.vault.azure.net/
AZURE_KEY_VAULT_SECRET_NAME=app-secrets

# ── GCP Secret Manager (requires: pip install google-cloud-secret-manager) ────
# Credentials: ADC (service account key / workload identity)
GCP_PROJECT_ID=                      # e.g. my-gcp-project
GCP_SECRET_NAME=                     # e.g. vidsage-db-secrets
GCP_SECRET_VERSION=latest

# ── Encrypted JSON file (requires: pip install cryptography) ──────────────────
# Generate key : python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# Encrypt file : python Scripts/encrypt_secrets.py /tmp/secrets.json app/data/secrets.enc.json
SECRETS_ENCRYPTED_FILE_PATH=         # absolute path to .enc.json file
SECRETS_ENCRYPTION_KEY=              # base64-encoded 32-byte AES key (supply at startup)

# Secret payload format (JSON, same for all cloud providers + encrypted file):
# {
#   "DATABASE_URL":    "postgresql+psycopg2://user:pass@host:5432/dbname",
#   "YOUTUBE_API_KEY": "AIza..."
# }
